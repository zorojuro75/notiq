{
    "title": "notiq",
    "uid": "notiq-main",
    "version": 1,
    "schemaVersion": 38,
    "panels": [
      {
        "id": 1,
        "title": "Jobs enqueued per minute",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "rate(notiq_jobs_enqueued_total[1m])",
            "legendFormat": "{{type}}"
          }
        ]
      },
      {
        "id": 2,
        "title": "Jobs processed per minute",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "rate(notiq_jobs_processed_total[1m])",
            "legendFormat": "{{type}} - {{status}}"
          }
        ]
      },
      {
        "id": 3,
        "title": "Active worker goroutines",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "notiq_worker_pool_active_goroutines",
            "legendFormat": "active"
          }
        ]
      },
      {
        "id": 4,
        "title": "Job processing duration (p95)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(notiq_job_processing_duration_seconds_bucket[5m]))",
            "legendFormat": "p95 {{type}}"
          }
        ]
      },
      {
        "id": 5,
        "title": "HTTP request rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
        "targets": [
          {
            "expr": "rate(notiq_http_requests_total[1m])",
            "legendFormat": "{{method}} {{path}} {{status}}"
          }
        ]
      }
    ],
    "time": { "from": "now-1h", "to": "now" },
    "refresh": "10s"
  }