APP_PORT=8080

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=notiq
DB_SSLMODE=disable
DB_LOG_LEVEL=warn

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Admin basic-auth credentials — both are REQUIRED; the API refuses to start if
# either is empty. Change the password before deploying anywhere real.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

LOG_LEVEL=info
LOG_FORMAT=json

# Disables the outbound SSRF guard so webhooks can target loopback/private
# addresses. DEV ONLY — never enable in production.
WEBHOOK_ALLOW_PRIVATE=false
